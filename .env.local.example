# Copy this file to .env.local for local development.
# In production (Vercel), set these as Environment Variables in the project settings instead —
# never commit your real keys to GitHub.

CLOUDCONVERT_API_KEY=your_cloudconvert_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@your_project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
